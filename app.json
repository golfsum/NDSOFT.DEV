{
  "expo": {
    "name": "BuildPad",
    "slug": "testflight-tracker",
    "scheme": "buildtracker",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ndsoft.testflighttracker",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-iap",
        {}
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
